// AffilMarket Kenya — Prisma Schema
// PostgreSQL via Supabase
// All monetary values in KES (Decimal 10,2)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  VENDOR
  AFFILIATE
  BOTH
  ADMIN
}

enum UserStatus {
  active
  suspended
  pending_verification
}

enum VendorStatus {
  pending
  approved
  rejected
  suspended
}

enum AffiliateStatus {
  active
  suspended
  pending
}

enum ProductStatus {
  draft
  pending_approval
  active
  rejected
  inactive
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  CREATED
  PAID
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PayoutMethod {
  MPESA
  BANK
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  PAID
  REJECTED
}

enum PayoutRole {
  VENDOR
  AFFILIATE
}

enum DisputeStatus {
  open
  resolved
}

enum MpesaTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  TIMEOUT
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash      String     @map("password_hash")
  phone             String?
  role              Role
  emailVerifiedAt   DateTime?  @map("email_verified_at")
  status            UserStatus @default(pending_verification)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  vendorProfile     VendorProfile?
  affiliateProfile  AffiliateProfile?
  balance           Balance?
  payoutRequests    PayoutRequest[]
  disputesOpened    DisputeTicket[] @relation("DisputeOpener")
  refreshTokens     RefreshToken[]
  verificationTokens EmailVerificationToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// ─────────────────────────────────────────────
// VENDOR PROFILES
// ─────────────────────────────────────────────

model VendorProfile {
  id          String       @id @default(uuid())
  userId      String       @unique @map("user_id")
  shopName    String       @map("shop_name")
  legalName   String?      @map("legal_name")
  phone       String?
  shopAddress Json?        @map("shop_address")
  kraPin      String?      @map("kra_pin")
  kraPinDoc   String?      @map("kra_pin_doc")
  logoUrl     String?      @map("logo_url")
  description String?
  status      VendorStatus @default(pending)
  avgRating   Decimal?     @map("avg_rating") @db.Decimal(3, 2)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  orders   Order[]
  reviews  Review[]

  @@map("vendor_profiles")
}

// ─────────────────────────────────────────────
// AFFILIATE PROFILES
// ─────────────────────────────────────────────

model AffiliateProfile {
  id                String          @id @default(uuid())
  userId            String          @unique @map("user_id")
  fullName          String          @map("full_name")
  phone             String?
  affiliateToken    String          @unique @map("affiliate_token")
  payoutMethod      PayoutMethod    @default(MPESA) @map("payout_method")
  mpesaPhone        String?         @map("mpesa_phone")
  bankName          String?         @map("bank_name")
  bankAccountName   String?         @map("bank_account_name")
  bankAccountNumber String?         @map("bank_account_number")
  idNumber          String?         @map("id_number")
  status            AffiliateStatus @default(pending)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks AffiliateClick[]
  orders Order[]

  @@map("affiliate_profiles")
}

// ─────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────

model Category {
  id           String     @id @default(uuid())
  name         String
  slug         String     @unique
  icon         String?
  parentId     String?    @map("parent_id")
  parent       Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryTree")
  products     Product[]  @relation("ProductCategory")
  subProducts  Product[]  @relation("ProductSubcategory")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("categories")
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

model Product {
  id                     String        @id @default(uuid())
  vendorId               String        @map("vendor_id")
  title                  String
  slug                   String        @unique
  shortDescription       String?       @map("short_description")
  description            String?
  categoryId             String?       @map("category_id")
  subcategoryId          String?       @map("subcategory_id")
  sku                    String?
  price                  Decimal       @db.Decimal(10, 2)
  stockQuantity          Int           @default(0) @map("stock_quantity")
  mainImageUrl           String?       @map("main_image_url")
  galleryImages          Json?         @map("gallery_images")
  affiliateCommissionRate Decimal      @default(0.10) @map("affiliate_commission_rate") @db.Decimal(4, 3)
  status                 ProductStatus @default(draft)
  country                String        @default("KE")
  adminNote              String?       @map("admin_note")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  vendor      VendorProfile    @relation(fields: [vendorId], references: [id])
  category    Category?        @relation("ProductCategory", fields: [categoryId], references: [id])
  subcategory Category?        @relation("ProductSubcategory", fields: [subcategoryId], references: [id])
  orders      Order[]
  clicks      AffiliateClick[]
  reviews     Review[]

  @@map("products")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id               String        @id @default(uuid())
  vendorId         String        @map("vendor_id")
  affiliateId      String?       @map("affiliate_id")
  productId        String        @map("product_id")
  price            Decimal       @db.Decimal(10, 2)
  quantity         Int           @default(1)
  totalAmount      Decimal       @map("total_amount") @db.Decimal(10, 2)
  customerName     String        @map("customer_name")
  customerPhone    String        @map("customer_phone")
  customerEmail    String?       @map("customer_email")
  country          String        @default("KE")
  city             String?
  address          String?
  notes            String?
  paymentStatus    PaymentStatus @default(PENDING) @map("payment_status")
  orderStatus      OrderStatus   @default(CREATED) @map("order_status")
  paymentReference String?       @map("payment_reference")
  mpesaReceiptNumber String?     @map("mpesa_receipt_number")
  deliveryMethod   String?       @map("delivery_method")
  deliveryTracking String?       @map("delivery_tracking")
  // Commission breakdown (immutable after computation)
  platformFee      Decimal?      @map("platform_fee") @db.Decimal(10, 2)
  affiliateCommission Decimal?   @map("affiliate_commission") @db.Decimal(10, 2)
  vendorEarnings   Decimal?      @map("vendor_earnings") @db.Decimal(10, 2)
  platformRevenue  Decimal?      @map("platform_revenue") @db.Decimal(10, 2)
  commissionsComputed Boolean    @default(false) @map("commissions_computed")
  balancesReleased Boolean       @default(false) @map("balances_released")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  vendor    VendorProfile     @relation(fields: [vendorId], references: [id])
  affiliate AffiliateProfile? @relation(fields: [affiliateId], references: [id])
  product   Product           @relation(fields: [productId], references: [id])
  review    Review?
  disputes  DisputeTicket[]
  mpesaTransactions MpesaTransaction[]

  @@map("orders")
}

// ─────────────────────────────────────────────
// M-PESA TRANSACTIONS
// ─────────────────────────────────────────────

model MpesaTransaction {
  id                String                 @id @default(uuid())
  orderId           String                 @map("order_id")
  checkoutRequestId String?                @unique @map("checkout_request_id")
  merchantRequestId String?                @map("merchant_request_id")
  phoneNumber       String                 @map("phone_number")
  amount            Decimal                @db.Decimal(10, 2)
  status            MpesaTransactionStatus @default(PENDING)
  mpesaReceiptNumber String?               @map("mpesa_receipt_number")
  resultCode        Int?                   @map("result_code")
  resultDesc        String?                @map("result_desc")
  rawCallback       Json?                  @map("raw_callback")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("mpesa_transactions")
}

// ─────────────────────────────────────────────
// AFFILIATE CLICKS
// ─────────────────────────────────────────────

model AffiliateClick {
  id          String   @id @default(uuid())
  affiliateId String   @map("affiliate_id")
  productId   String   @map("product_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  referrer    String?
  cookieToken String?  @map("cookie_token")
  createdAt   DateTime @default(now()) @map("created_at")

  affiliate AffiliateProfile @relation(fields: [affiliateId], references: [id])
  product   Product          @relation(fields: [productId], references: [id])

  @@index([affiliateId])
  @@index([cookieToken])
  @@map("affiliate_clicks")
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model Review {
  id         String   @id @default(uuid())
  orderId    String   @unique @map("order_id")
  productId  String   @map("product_id")
  vendorId   String   @map("vendor_id")
  rating     Int
  reviewText String?  @map("review_text")
  createdAt  DateTime @default(now()) @map("created_at")

  order   Order         @relation(fields: [orderId], references: [id])
  product Product       @relation(fields: [productId], references: [id])
  vendor  VendorProfile @relation(fields: [vendorId], references: [id])

  @@map("reviews")
}

// ─────────────────────────────────────────────
// BALANCES
// ─────────────────────────────────────────────

model Balance {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  pendingBalance   Decimal  @default(0) @map("pending_balance") @db.Decimal(10, 2)
  availableBalance Decimal  @default(0) @map("available_balance") @db.Decimal(10, 2)
  paidOutTotal     Decimal  @default(0) @map("paid_out_total") @db.Decimal(10, 2)
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("balances")
}

// ─────────────────────────────────────────────
// PAYOUT REQUESTS
// ─────────────────────────────────────────────

model PayoutRequest {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  role      PayoutRole
  amount    Decimal      @db.Decimal(10, 2)
  method    PayoutMethod
  status    PayoutStatus @default(REQUESTED)
  adminNote String?      @map("admin_note")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("payout_requests")
}

// ─────────────────────────────────────────────
// PLATFORM SETTINGS
// ─────────────────────────────────────────────

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

// ─────────────────────────────────────────────
// DISPUTE TICKETS
// ─────────────────────────────────────────────

model DisputeTicket {
  id         String        @id @default(uuid())
  orderId    String        @map("order_id")
  openedById String        @map("opened_by_id")
  messages   Json          @default("[]")
  status     DisputeStatus @default(open)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  order    Order @relation(fields: [orderId], references: [id])
  openedBy User  @relation("DisputeOpener", fields: [openedById], references: [id])

  @@map("dispute_tickets")
}

