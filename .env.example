# ============================================================
# AffilMarket Kenya — Environment Variables
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="AffilMarket Kenya"

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-SUPABASE-ANON-KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SUPABASE-SERVICE-ROLE-KEY]

# --- JWT Auth ---
JWT_SECRET=[GENERATE: openssl rand -base64 64]
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=[GENERATE: openssl rand -base64 64]
REFRESH_TOKEN_EXPIRES_IN=30d

# --- M-Pesa / Daraja API (Safaricom) ---
MPESA_CONSUMER_KEY=[YOUR-DARAJA-CONSUMER-KEY]
MPESA_CONSUMER_SECRET=[YOUR-DARAJA-CONSUMER-SECRET]
MPESA_PASSKEY=[YOUR-DARAJA-PASSKEY]
MPESA_SHORTCODE=[YOUR-MPESA-SHORTCODE]
MPESA_ENVIRONMENT=sandbox
# sandbox: https://sandbox.safaricom.co.ke
# production: https://api.safaricom.co.ke
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
# STK Push callback — must be publicly accessible (use ngrok in dev)
MPESA_CALLBACK_URL=https://[YOUR-NGROK-OR-DOMAIN]/api/webhooks/mpesa/callback

# --- Cloudinary (Image Storage) ---
CLOUDINARY_CLOUD_NAME=[YOUR-CLOUD-NAME]
CLOUDINARY_API_KEY=[YOUR-API-KEY]
CLOUDINARY_API_SECRET=[YOUR-API-SECRET]

# --- Resend (Email) ---
RESEND_API_KEY=[YOUR-RESEND-API-KEY]
RESEND_FROM_EMAIL=noreply@affilmarket.co.ke

# --- Redis (Upstash) ---
UPSTASH_REDIS_REST_URL=https://[YOUR-UPSTASH-ENDPOINT].upstash.io
UPSTASH_REDIS_REST_TOKEN=[YOUR-UPSTASH-TOKEN]

# --- Platform Settings (defaults, overridden by DB settings) ---
PLATFORM_FEE_RATE=0.05
PLATFORM_FIXED_FEE=10
MIN_PAYOUT_THRESHOLD=500
AFFILIATE_COOKIE_DAYS=30

# --- Webhook Security ---
MPESA_WEBHOOK_SECRET=[GENERATE: openssl rand -hex 32]
